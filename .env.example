## Sanity (optional)
## If you enable Sanity, set these in Vercel/host environment variables.
SANITY_PROJECT_ID=
SANITY_DATASET=production
SANITY_API_VERSION=2026-01-01

## Contact form (recommended for production)
## Vercel KV env vars are auto-provisioned when you add the Vercel KV/Redis integration.
## Email sending uses Resend (recommended). If empty, form still returns success but won't email.
RESEND_API_KEY=
LEADS_FROM_EMAIL=PixelPulse <onboarding@resend.dev>
LEADS_TO_EMAIL=

## Rate limit settings (optional)
CONTACT_RATE_LIMIT_WINDOW_SECONDS=600
CONTACT_RATE_LIMIT_MAX=6

